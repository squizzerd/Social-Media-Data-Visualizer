# Function to split tags except for "Student Centered, Innovation Driven"
split_tags <- function(tag_string) {
if (tag_string == "" || is.na(tag_string)) {
return(character(0))
}
# Replace the special case with a placeholder
temp <- str_replace_all(tag_string, "Student Centered, Innovation Driven", "PLACEHOLDER_SCID")
# Split by comma
split <- str_split(temp, ",\\s*")[[1]]
# Replace placeholder back
split <- str_replace_all(split, "PLACEHOLDER_SCID", "Student Centered, Innovation Driven")
return(split)
}
# Apply to all tags
all_individual_tags <- unlist(lapply(tags, split_tags))
library(stringr)
# Function to split tags except for "Student Centered, Innovation Driven"
split_tags <- function(tag_string) {
if (tag_string == "" || is.na(tag_string)) {
return(character(0))
}
# Replace the special case with a placeholder
temp <- str_replace_all(tag_string, "Student Centered, Innovation Driven", "PLACEHOLDER_SCID")
# Split by comma
split <- str_split(temp, ",\\s*")[[1]]
# Replace placeholder back
split <- str_replace_all(split, "PLACEHOLDER_SCID", "Student Centered, Innovation Driven")
return(split)
}
# Apply to all tags
all_individual_tags <- unlist(lapply(tags, split_tags))
# Get unique tags
unique_tags <- unique(all_individual_tags)
ig_stats_expanded <- ig_stats |>
mutate(individual_tags = map(Content.Type, split_tags)) |>
unnest(individual_tags)
